# Firebase Web App configuration
# Copy this file to .env (never commit .env!) and fill in your project's values.
# All values are found in the Firebase Console → Project Settings → Your apps → Web app.
#
# For GitHub Pages deployment these are stored as GitHub Secrets (see README.md).

FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=1:your_sender_id:web:your_app_hash
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
